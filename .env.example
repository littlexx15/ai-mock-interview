# AI 模拟面试器 - 环境变量示例
# 复制此文件为 .env 并填入实际值

# ===== 主 LLM 配置 =====
# OpenAI API Key（使用 OpenAI 时必填）
OPENAI_API_KEY=sk-your-openai-api-key-here

# API 基地址（使用 Azure OpenAI 或本地代理时配置）
# 留空则使用 OpenAI 官方地址
OPENAI_API_BASE=

# 模型名称（如 gpt-4o, gpt-4o-mini, gpt-3.5-turbo）
LLM_MODEL=gpt-4o-mini

# ===== 语音（STT/TTS，与 OpenAI 兼容音频接口）=====
# STT_MODEL=whisper-1
# TTS_MODEL=tts-1
# TTS_VOICE=alloy

# 云端部署（Streamlit Cloud / Render / Railway）请用平台「Secrets」或「环境变量」
# 配置同名键，勿将真实密钥提交到 Git。详见 DEPLOYMENT.md。
