# AI 模拟面试器 - 环境变量示例
# 复制此文件为 .env 并填入实际值

# ===== 主 LLM（OpenAI 兼容 SDK，可接 DeepSeek / OpenAI 等）=====
OPENAI_API_KEY=sk-ffaee47888014fddbc97626f214719e7

# 示例：DeepSeek（聊天）
# OPENAI_API_BASE=https://api.deepseek.com/v1
# LLM_MODEL=deepseek-chat

# 示例：OpenAI 官方（可不设 OPENAI_API_BASE，或设为 https://api.openai.com/v1）
# LLM_MODEL=gpt-4o-mini

OPENAI_API_BASE=
LLM_MODEL=deepseek-chat

# 请求超时（秒）
OPENAI_TIMEOUT=180

# ===== 语音 STT/TTS（需 OpenAI 兼容 Audio 接口；DeepSeek 聊天域名无 whisper/tts）=====
# 仅使用 DeepSeek 做面试对话时：若要语音作答，请配置支持 Audio 的网关与密钥，例如：
# SPEECH_API_BASE=https://api.openai.com/v1
# SPEECH_API_KEY=sk-your-openai-key-for-whisper-tts
# STT_MODEL=whisper-1
# TTS_MODEL=tts-1
# TTS_VOICE=alloy

# 云端部署（Streamlit Cloud / Render / Railway）请用平台「Secrets」或「环境变量」
# 配置同名键，勿将真实密钥提交到 Git。详见 DEPLOYMENT.md。
